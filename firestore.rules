rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isUser(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Public events (anyone can read published events) ───────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );

      // Sub-collection tickets (admin + organizer can read all)
      match /tickets/{ticketId} {
        allow read: if isAuth() && (
          resource.data.buyerUid == request.auth.uid ||
          resource.data.organizerId == request.auth.uid ||
          resource.data.vendorId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isAuth();
        allow update: if isAuth() && (
          resource.data.organizerId == request.auth.uid || isAdmin()
        );
      }
    }

    // ── Top-level tickets (legacy path) ───────────────────────────
    match /tickets/{ticketId} {
      allow read: if isAuth() && (
        resource.data.buyerUid == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Organizer profiles ─────────────────────────────────────────
    match /organizers/{uid} {
      allow read: if isAuth();
      allow write: if isUser(uid) || isAdmin();
    }

    // ── Fan/user profiles ──────────────────────────────────────────
    match /users/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow write: if isUser(uid) || isAdmin();
    }

    // ── Vendor profiles ────────────────────────────────────────────
    match /vendors/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource == null ||
        resource.data.uid == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
    }

    // ── Refund requests ────────────────────────────────────────────
    match /refundRequests/{docId} {
      allow read: if isAuth() && (
        resource.data.buyerUid == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Venues ─────────────────────────────────────────────────────
    match /venues/{venueId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Vendor requests ────────────────────────────────────────────
    match /vendorRequests/{docId} {
      allow read: if isAuth() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Vendor purchases ───────────────────────────────────────────
    match /vendorPurchases/{docId} {
      allow read: if isAuth() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Staff pool ─────────────────────────────────────────────────
    match /staffPool/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    match /staffAssignments/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Floor plans (public — shared by venue) ─────────────────────
    match /floorPlans/{placeId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ── Event layouts (private — organizer's zone arrangement) ─────
    match /eventLayouts/{eventId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Vendor sales history ───────────────────────────────────────
    match /vendorSales/{docId} {
      allow read: if isAuth() && (
        resource.data.vendorId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth();
    }

    // ── F&B sales (scanner) ────────────────────────────────────────
    match /fbSales/{docId} {
      allow read: if isAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth();
    }

    // ── Door staff (events sub-collection) ────────────────────────
    match /events/{eventId}/doorStaff/{staffId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid
        || isAdmin()
      );
    }

    // ── Bar POS (public — protected by barCode URL) ────────────────
    match /barStations/{docId} {
      allow read: if true;
      allow create, delete: if isAuth();
      allow update: if true;
    }
    match /barItems/{docId} {
      allow read: if true;
      allow create, delete: if isAuth();
      allow update: if true;
    }
    match /barOrders/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
    match /barConfig/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Legal docs (public static) ─────────────────────────────────
    match /legal/{file} {
      allow read: if true;
    }
  }
}
