rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function isUser(uid) { return isAuth() && request.auth.uid == uid; }

    function isAdmin() {
      return isAuth() && request.auth.uid == '4tnDCh99SFR4KFqYnTxYTIRfN8j2';
    }

    function isActiveAuth() {
      return isAuth();
    }

    function isApprovedOrganizer() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.role == 'organizer' && (
        !('organizerStatus' in u) || u.organizerStatus == 'approved'
      );
    }

    // ── Public events ──────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isActiveAuth() && (isApprovedOrganizer() || isAdmin());
      allow update, delete: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );

      match /tickets/{ticketId} {
        allow read: if isActiveAuth();
        allow create: if isActiveAuth();
        allow update: if isActiveAuth() && (
          resource.data.organizerId == request.auth.uid || isAdmin()
        );
        allow delete: if isAdmin();
      }

      match /doorStaff/{staffId} {
        allow read: if isActiveAuth();
        allow write: if isActiveAuth() && (
          get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid
          || isAdmin()
        );
      }
    }

    // ── Top-level tickets ──────────────────────────────────────────
    match /tickets/{ticketId} {
      allow read: if isActiveAuth() && (
        resource.data.buyerEmail == request.auth.token.email ||
        resource.data.organizerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isActiveAuth();
      allow update: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.buyerEmail == request.auth.token.email ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Organizer profiles ─────────────────────────────────────────
    match /organizers/{uid} {
      allow read: if isActiveAuth();
      allow write: if isActiveAuth() && (isUser(uid) || isAdmin());

      match /drafts/{draftId} {
        allow read, write: if isActiveAuth() && isUser(uid);
      }
    }

    // ── User profiles ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow create: if isAuth();
      allow update: if isActiveAuth() && (isUser(uid) || isAdmin());
      allow delete: if isAdmin();

      match /drafts/{draftId} {
        allow read, write: if isActiveAuth() && isUser(uid);
      }
    }

    // ── Vendors ────────────────────────────────────────────────────
    match /vendors/{docId} {
      allow read: if isActiveAuth();
      allow create: if isActiveAuth();
      allow update, delete: if isActiveAuth() && (
        resource.data.uid == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
    }

    // ── Vendor requests ────────────────────────────────────────────
    match /vendorRequests/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isActiveAuth();
      allow update: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Vendor purchases ───────────────────────────────────────────
    match /vendorPurchases/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isActiveAuth();
      allow update: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Refund requests ────────────────────────────────────────────
    match /refundRequests/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.buyerUid == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isActiveAuth();
      allow update: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Payout requests ────────────────────────────────────────────
    match /payoutRequests/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow create: if isActiveAuth() && (isApprovedOrganizer() || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Venues ────────────────────────────────────────────────────
    match /venues/{venueId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Platform config ────────────────────────────────────────────
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Audit log ─────────────────────────────────────────────────
    match /auditLog/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Staff pool ─────────────────────────────────────────────────
    match /staffPool/{docId} {
      allow read: if isActiveAuth();
      allow create: if isActiveAuth() && (isApprovedOrganizer() || isAdmin());
      allow update, delete: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    match /staffAssignments/{docId} {
      allow read: if isActiveAuth();
      allow create: if isActiveAuth() && (isApprovedOrganizer() || isAdmin());
      allow update, delete: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
    }

    // ── Staff (door staff collection) ──────────────────────────────
    match /staff/{docId} {
      allow read: if isActiveAuth();
      allow write: if isActiveAuth() && (
        resource == null ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
    }

    // ── Floor plans ────────────────────────────────────────────────
    match /floorPlans/{placeId} {
      allow read: if true;
      allow create, update: if isActiveAuth();
      allow delete: if isAdmin();
    }

    // ── Event layouts ──────────────────────────────────────────────
    match /eventLayouts/{eventId} {
      allow read: if isActiveAuth();
      allow write: if isActiveAuth();
    }

    // ── Vendor sales ───────────────────────────────────────────────
    match /vendorSales/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.vendorId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isActiveAuth();
      allow update, delete: if isAdmin();
    }

    // ── F&B sales ──────────────────────────────────────────────────
    match /fbSales/{docId} {
      allow read: if isActiveAuth() && (
        resource.data.organizerId == request.auth.uid || isAdmin()
      );
      allow create: if isActiveAuth();
      allow update, delete: if isAdmin();
    }

    // ── Bar POS (protected by barCode URL param) ───────────────────
    match /barStations/{docId} {
      allow read: if true;
      allow create, delete: if isActiveAuth();
      allow update: if true;
    }
    match /barItems/{docId} {
      allow read: if true;
      allow create, delete: if isActiveAuth();
      allow update: if true;
    }
    match /barOrders/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
    match /barConfig/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Legal docs ─────────────────────────────────────────────────
    match /legal/{file} {
      allow read: if true;
    }
  }
}
